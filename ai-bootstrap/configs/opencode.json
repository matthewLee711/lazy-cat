{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "openspec": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@fission-ai/openspec-mcp"
      ],
      "enabled": true
    }
  }
}
